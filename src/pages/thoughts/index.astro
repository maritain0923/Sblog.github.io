---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('thoughts'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="随想" titleEn="Thoughts">
  <header class="mb-10">
    <div class="text-[0.68rem] font-mono tracking-[0.18em] text-faint uppercase mb-2">Thoughts</div>
    <h1 class="text-2xl font-sans font-medium text-ink">
      <span class="zh">随想</span><span class="en">Thoughts</span>
    </h1>
    <p class="text-faint text-[0.8rem] mt-1.5">
      <span class="zh">碎片思考，不成体系，也包含一些牢骚</span>
      <span class="en">Fragments, feelings, and the occasional rant</span>
    </p>
  </header>

  {posts.length === 0 ? (
    <p class="text-center py-20 text-faint text-sm">
      <span class="zh">脑子里有什么就写下来吧。</span>
      <span class="en">Whatever's on your mind, write it down.</span>
    </p>
  ) : (
    <div class="space-y-2.5">
      {posts.map(post => (
        <a
          href={`/thoughts/${post.slug}`}
          class="group flex items-start gap-5 border border-line/60 rounded-xl px-5 py-4 hover:border-accent/30 hover:bg-accentL/20 transition-all"
        >
          <time class="font-mono text-[0.67rem] text-faint shrink-0 mt-0.5 w-10">
            {post.data.date.toLocaleDateString('zh-CN', { month:'2-digit', day:'2-digit' })}
          </time>
          <div class="flex-1 min-w-0">
            <div class="text-[0.9rem] font-medium text-ink group-hover:text-accent transition-colors mb-1">
              <span class="zh">{post.data.title}</span>
              <span class="en">{post.data.titleEn ?? post.data.title}</span>
            </div>
            {post.data.description && (
              <p class="text-[0.75rem] text-faint leading-5 line-clamp-2">
                <span class="zh">{post.data.description}</span>
                <span class="en">{post.data.descriptionEn ?? post.data.description}</span>
              </p>
            )}
          </div>
          <span class="text-faint text-sm mt-0.5 group-hover:translate-x-0.5 transition-transform">→</span>
        </a>
      ))}
    </div>
  )}
</Layout>
